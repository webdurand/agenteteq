# Configuração de Pesquisa Web (padrão: duckduckgo - gratuito, sem API key)
# Opções: duckduckgo, tavily, exa, serper, brave
# SEARCH_PROVIDER=duckduckgo

# Configuração de Scraping (padrão: newspaper4k - gratuito, sem API key)
# Opções: newspaper4k, crawl4ai
# SCRAPER_PROVIDER=newspaper4k

# API Keys de provedores opcionais de pesquisa (só necessárias ao trocar o padrão)
# TAVILY_API_KEY=tvly-xxxxx        (tavily.com - 1000 buscas/mês grátis, sem cartão)
# EXA_API_KEY=                     (exa.ai)
# SERPER_API_KEY=                  (serper.dev - 2500 buscas grátis)
# BRAVE_API_KEY=                   (brave.com/search/api - gratuito)
