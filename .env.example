# Configurações do Agente/Transcrição
TRANSCRIBER_PROVIDER=mock
OPENAI_API_KEY=sua_api_key_aqui
GEMINI_API_KEY=sua_api_key_do_google_aqui
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
AGNO_DB_URL=libsql://agenteteq-durand.aws-us-east-1.turso.io
