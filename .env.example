# ============================================
# WhatsApp
# ============================================
WHATSAPP_VERIFY_TOKEN=meu_token_super_secreto
WHATSAPP_API_TOKEN=seu_token_da_cloud_api_aqui
WHATSAPP_PHONE_NUMBER_ID=seu_id_de_telefone_aqui
# WHATSAPP_PROVIDER=meta            # meta (padrão) | evolution
# WHATSAPP_APP_SECRET=              # obrigatório em produção para validar webhooks Meta

# Evolution API (se WHATSAPP_PROVIDER=evolution)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_TOKEN=
# EVOLUTION_INSTANCE_NAME=

# ============================================
# Banco de Dados
# ============================================
# DATABASE_URL=                     # SQLAlchemy connection string (fallback: SQLite local)
AGNO_DB_URL=libsql://agenteteq-durand.aws-us-east-1.turso.io

# ============================================
# LLM / Agente
# ============================================
TRANSCRIBER_PROVIDER=mock
OPENAI_API_KEY=sua_api_key_aqui
GEMINI_API_KEY=sua_api_key_do_google_aqui
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
# GEMINI_GOOGLE_SEARCH=true        # Habilita grounding com Google Search nativo
# LLM_DECOMPOSE_MODEL=             # modelo para decomposição de workflows
# MEMORY_MODE=                     # modo de memória do agente
# GEMINI_THINKING_BUDGET=          # budget de pensamento do Gemini

# ============================================
# GitHub (Publicação no Blog)
# ============================================
GITHUB_TOKEN=seu_token_do_github_aqui
GITHUB_REPO=webdurand/diario-teq

# ============================================
# Pesquisa Web
# ============================================
# Opções: duckduckgo, tavily, exa, serper, brave
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=                    # (tavily.com - 1000 buscas/mês grátis)
# EXA_API_KEY=                     # (exa.ai)
# SERPER_API_KEY=                  # (serper.dev - 2500 buscas grátis)
# BRAVE_API_KEY=                   # (brave.com/search/api - gratuito)

# Scraping: jina, newspaper4k, crawl4ai
# SCRAPER_PROVIDER=jina

# ============================================
# Autenticação
# ============================================
JWT_SECRET=meu-segredo-jwt-super-secreto
OTP_EXPIRY_SECONDS=120
TOKEN_ENCRYPTION_KEY=chave-secreta-para-encriptar-tokens-oauth
GOOGLE_CLIENT_ID=seu_client_id_do_google_aqui
# GOOGLE_CLIENT_SECRET=            # necessário para OAuth completo
# GOOGLE_API_KEY=                  # necessário para Google APIs

# ============================================
# Frontend
# ============================================
# ENV=dev                          # dev | prod (afeta segurança e comportamento)
# FRONTEND_ORIGIN=https://teq.ia.br  # origem do frontend React (CORS)
# FRONTEND_URL=https://teq.ia.br    # URL completa do frontend (redirecionamentos)

# ============================================
# Billing (Stripe)
# ============================================
# STRIPE_SECRET_KEY=               # obrigatório para billing
# STRIPE_WEBHOOK_SECRET=           # obrigatório em produção para validar webhooks

# ============================================
# TTS / Voz
# ============================================
# TTS_PROVIDER=gemini              # gemini (padrão) | openai | elevenlabs | browser
# TTS_VOICE=Aoede                  # Gemini: Aoede, Fenrir, Puck, Charon, Kore | OpenAI: onyx, nova, shimmer...
# ELEVENLABS_API_KEY=              # só necessário se TTS_PROVIDER=elevenlabs

# Fluxo de Voz Real-time (Gemini Live API)
VOICE_REALTIME_MODEL=gemini-2.0-flash-live
VOICE_REALTIME_VOICE=Puck
# VOICE_LIVE_IDLE_TIMEOUT_SECONDS=30

# ============================================
# Integração Slack (OAuth)
# ============================================
SLACK_CLIENT_ID=seu_client_id_do_slack_aqui
SLACK_CLIENT_SECRET=seu_client_secret_do_slack_aqui

# ============================================
# Imagens
# ============================================
# IMAGE_PROVIDER=                  # provedor de geração de imagens
# IMAGE_MODEL=                     # modelo de imagem
# IMAGE_FALLBACK_ENABLED=false     # habilitar fallback
# IMAGE_FALLBACK_MODEL=            # modelo de fallback
# FAL_KEY=                         # fal.ai API key

# Cloudinary (upload de imagens)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ============================================
# Video
# ============================================
# VIDEO_PROVIDER=                  # provedor de vídeo
# DID_API_KEY=                     # D-ID API key
# HEYGEN_API_KEY=                  # HeyGen API key

# ============================================
# Social Media Monitoring
# ============================================
# APIFY_API_TOKEN=                 # Apify para scraping Instagram
# RAPIDAPI_KEY=                    # RapidAPI alternativo
# RAPIDAPI_INSTAGRAM_HOST=
# YOUTUBE_API_KEY=                 # YouTube Data API
# SOCIAL_FETCH_INTERVAL_HOURS=6   # frequência de fetch

# ============================================
# Monitoramento
